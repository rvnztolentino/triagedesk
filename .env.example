# Required for TriageDesk AI triage.
AI_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-20b

# Required Supabase project settings. Keep the service-role key server-only.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Required for bootstrapping the protected owner. Signup with this email becomes owner.
SEED_ADMIN_EMAIL=admin@example.com

# Optional outside local/Vercel. Used for Supabase email verification links.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Required only when attaching request images. Create this Supabase Storage bucket in setup.
SUPABASE_REQUEST_IMAGES_BUCKET=request-images
